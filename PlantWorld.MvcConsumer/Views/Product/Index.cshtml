@model IEnumerable<PlantWorld.MvcConsumer.Models.ProductDTOs.ProductDTO>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Products";
}

<h2>كل المنتجات</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">إضافة منتج جديد</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>الأسم</th>
            <th>الصورة</th>
            <th>الوصف</th>
            <th>التفاعلات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImgUrl))
                    {
                        <img src="@item.ImgUrl" width="100" />
                    }
                </td>
                <td>@item.Description</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">تعديل</a> |
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">عرض التفاصيل</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">حذف</a>
                </td>
            </tr>
        }
    </tbody>
</table>


@* Pagination *@
<div class="pagination">
    @if (ViewBag.TotalPages > 1)
    {
        for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            if (i == ViewBag.CurrentPage)
            {
                <span class="btn btn-dark m-1">@i</span>
            }
            else
            {
                <a class="btn btn-outline-dark m-1" href="/Product/Index?page=@i">@i</a>
            }
        }
    }
</div>
<style>
    .pagination {
        margin-top: 20px;
    }
</style>